{
  "name": "distributed-task-system",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "devDependencies": {
    "typescript": "^5.3.3",
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/parser": "^6.20.0",
    "@typescript-eslint/eslint-plugin": "^6.20.0",
    "prettier": "^3.2.4"
  }
}
