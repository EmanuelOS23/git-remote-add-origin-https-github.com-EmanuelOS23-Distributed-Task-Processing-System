generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Representa o Usuário do sistema
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tasks     Task[] // Relacionamento 1-N (Um usuário pode ter várias tarefas)

  @@map("users")
}

// Representa uma Tarefa a ser processada
model Task {
  id          String     @id @default(uuid())
  title       String
  description String?
  status      TaskStatus @default(PENDING)
  payload     Json? // Dados adicionais caso o Worker precise processar algo específico
  userId      String
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user User      @relation(fields: [userId], references: [id])
  logs TaskLog[] // Relacionamento 1-N (Uma tarefa pode ter vários logs de execução)

  @@map("tasks")
}

// Representa o Log/histórico de execução de uma tarefa
model TaskLog {
  id        String     @id @default(uuid())
  taskId    String
  status    TaskStatus
  message   String
  createdAt DateTime   @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@map("task_logs")
}

// Enumeração restrita de status da tarefa
enum TaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}
